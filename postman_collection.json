    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "name",
                  "value": "Laptop",
                  "type": "text"
                },
                {
                  "key": "sku",
                  "value": "SKU-001",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "Electronics",
                  "type": "text"
                },
                {
                  "key": "purchasePrice",
                  "value": "500",
                  "type": "text"
                },
                {
                  "key": "sellingPrice",
                  "value": "800",
                  "type": "text"
                },
                {
                  "key": "stockQuantity",
                  "value": "10",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/v1/products",
              "host": ["http://localhost:5000"],
              "path": ["api", "v1", "products"]
            }
          }
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/v1/products",
              "host": ["http://localhost:5000"],
              "path": ["api", "v1", "products"]
            }
          }
        }
      ]
    },
