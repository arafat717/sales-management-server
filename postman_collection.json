              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CUSTOM_MANAGER\",\n  \"description\": \"Custom manager role\",\n  \"permissions\": [\n    {\n      \"resource\": \"products\",\n      \"actions\": [\"create\", \"read\", \"update\"]\n    },\n    {\n      \"resource\": \"sales\",\n      \"actions\": [\"create\", \"read\"]\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/v1/roles",
              "host": ["http://localhost:5000"],
