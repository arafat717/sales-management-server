          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Rahman\",\n  \"email\": \"alice@example.com\",\n  \"phone\": \"01811111111\",\n  \"address\": \"Chittagong\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/v1/customers",
              "host": ["http://localhost:5000"],
              "path": ["api", "v1", "customers"]
